    {"id": "contemplative", "terms": [], "undertone": "hesitation", "valence": "neutral", "arousal": "low", "expression": "restrained", "energy": "slow", "tension": "suspended", "arc": {"start": "observation", "turn": "decision", "end": "aftertaste"}}
