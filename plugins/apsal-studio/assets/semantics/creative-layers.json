    "subject": ["identity", "representation", "identity_locks"],
    "world": ["space", "time", "materials", "physical_rules", "continuity"],
    "look": ["wardrobe", "grooming", "props", "ownership_policy"],
    "event": ["inciting_action", "state_changes", "consequences"],
    "sequence": ["strategy", "rhythm", "progression", "shot_count"],
