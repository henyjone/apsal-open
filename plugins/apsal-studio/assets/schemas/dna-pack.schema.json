{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/henyjone/apsal-open/schemas/dna-pack.schema.json",
  "title": "APSAL DNA Extension Pack 0.6",
  "type": "object",
  "required": ["schema_version", "protocol", "protocol_version", "pack_id", "namespace", "version", "name", "description", "distribution", "redistribution_allowed", "assets", "asset_count", "files"],
  "properties": {
    "schema_version": {"const": "0.6.0"},
    "protocol": {"const": "apsal-open"},
    "protocol_version": {"const": "0.3.0"},
    "pack_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "namespace": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "distribution": {"enum": ["public", "private_only"]},
    "redistribution_allowed": {"type": "boolean"},
    "assets": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "asset_count": {"type": "integer", "minimum": 1},
    "files": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
  },
  "additionalProperties": false
}
