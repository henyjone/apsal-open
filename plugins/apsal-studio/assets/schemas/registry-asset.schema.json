{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/henyjone/apsal-open/schemas/registry-asset.schema.json",
  "title": "APSAL Local Registry Asset 0.6",
  "type": "object",
  "required": ["schema_version", "namespace", "id", "type", "version", "status", "parent_version", "changed_fields", "change_summary", "prompt_fragment", "negative_fragment", "rights", "qa_status"],
  "properties": {
    "schema_version": {"type": "string"},
    "namespace": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"},
    "type": {"enum": ["character", "style", "environment", "lighting", "composition", "shot", "qa"]},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"type": "string", "minLength": 1},
    "parent_version": {"type": ["string", "null"]},
    "changed_fields": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "change_summary": {"type": "string", "minLength": 1},
    "prompt_fragment": {"type": "string", "minLength": 1},
    "negative_fragment": {"type": "string"},
    "rights": {"type": "object", "required": ["license", "status", "attribution"]},
    "qa_status": {"type": "string", "minLength": 1},
    "discovery": {"$ref": "discovery.schema.json"}
  },
  "additionalProperties": true
}
