{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apsal.open/schemas/theme.schema.json",
  "title": "APSAL Open Theme",
  "type": "object",
  "required": ["schema_version", "id", "version", "name", "parent_version", "changed_fields", "change_summary", "dna", "output", "shots", "rights", "qa_status"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9-]*$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "shots": {"type": "array", "minItems": 1, "maxItems": 24},
    "qa_status": {"enum": ["static_validated", "visual_qa_pending", "visual_qa_passed"]}
  },
  "additionalProperties": true
}
