{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apsal.open/schemas/theme.schema.json",
  "title": "APSAL Open Theme",
  "type": "object",
  "required": ["schema_version", "id", "version", "name", "parent_version", "changed_fields", "change_summary", "dna", "output", "shots", "rights", "qa_status"],
  "properties": {
    "schema_version": {"enum": ["1.0.0", "1.1.0"], "description": "Theme data-model version. / 主题数据模型版本。"},
    "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9-]*$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "semantic_contract_version": {"const": "0.3.0", "description": "Semantic Contract version used by authoring intent. / 创作意图采用的语义契约版本。"},
    "semantics": {"$ref": "semantic-contract.schema.json"},
    "protocol_mapping": {"type": "object", "description": "Registered mapping from seven creator-facing DNA categories to thirteen protocol roles. / 七类创作 DNA 到十三类协议角色的注册映射。"},
    "element_semantics": {"type": "object", "description": "Meaning and constraints for all thirteen protocol roles. / 十三类协议角色的含义与约束。"},
    "interaction_model": {"enum": ["five_layer_thirteen_element"]},
    "element_decisions": {
      "type": "object",
      "required": ["subject", "world", "style", "look", "emotion", "event", "camera", "light", "color_post", "quality_control", "content", "sequence", "job"],
      "additionalProperties": {"$ref": "element-decision.schema.json"},
      "description": "Creator-confirmed values and provenance for all thirteen protocol roles. / 十三类协议角色经创作者确认的取值与来源。"
    },
    "rendering_contract": {"$ref": "rendering-contract.schema.json"},
    "references": {"type": "array", "items": {"$ref": "reference-manifest.schema.json#/$defs/reference"}},
    "distribution": {"enum": ["public", "private_only"]},
    "shots": {"type": "array", "minItems": 1, "maxItems": 24, "description": "Independent photographic Jobs in narrative order. / 按叙事顺序排列的独立摄影 Job。"},
    "qa_status": {"enum": ["static_validated", "visual_qa_pending", "visual_qa_passed"]}
  },
  "allOf": [{
    "if": {"properties": {"schema_version": {"const": "1.1.0"}}},
    "then": {"required": ["semantic_contract_version", "semantics", "protocol_mapping", "element_semantics"]}
  }],
  "additionalProperties": true
}
